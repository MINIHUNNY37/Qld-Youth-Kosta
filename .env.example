# Postgres connection string (Neon, Supabase, Vercel Postgres, etc.)
# Local-only hint: you can point this at a free Neon dev branch.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT signing secret — MUST be a long random string (>= 32 chars) in production.
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# Bootstrap admin account (created the first time the app runs if missing).
ADMIN_EMAIL="admin@qldyouthkosta.org"
ADMIN_PASSWORD="changeme-please"
ADMIN_NAME="KOSTA Admin"

# Vercel Blob storage token. Provided automatically when you connect a Blob
# store to a Vercel project. Needed only for PDF/image uploads.
BLOB_READ_WRITE_TOKEN=""
