// Prisma schema for QLD Youth KOSTA community app.
// Uses PostgreSQL in production (e.g. Neon) — swap `provider` to "sqlite"
// for local-only experiments.
// Note: the original SQLite design used String fields instead of enums for
// portability; Postgres would support enums but we kept strings so the same
// schema works across both engines.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("USER") // "USER" | "ADMIN"
  createdAt    DateTime @default(now())

  prayerNotes PrayerNote[]
  comments    Comment[]
  resources   Resource[]
}

model PrayerNote {
  id          String   @id @default(cuid())
  title       String
  content     String
  status      String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  isAnonymous Boolean  @default(false)
  authorName  String   @default("Anon") // shown when isAnonymous is false
  prayedCount Int      @default(0)
  heartCount  Int      @default(0)
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId    String?
  comments    Comment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, createdAt])
}

model Comment {
  id            String     @id @default(cuid())
  content       String
  author        User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  prayerNote    PrayerNote @relation(fields: [prayerNoteId], references: [id], onDelete: Cascade)
  prayerNoteId  String
  createdAt     DateTime   @default(now())

  @@index([prayerNoteId, createdAt])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String?  // present for PDF/IMAGE, null for LYRICS
  fileName    String?  // present for PDF/IMAGE, null for LYRICS
  fileType    String   // "PDF" | "IMAGE" | "LYRICS"
  lyrics      String?  // present when fileType == "LYRICS"
  uploader    User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  uploaderId  String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
