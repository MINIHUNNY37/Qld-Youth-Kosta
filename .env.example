# SQLite database file (relative to the prisma/ directory)
DATABASE_URL="file:./dev.db"

# JWT signing secret — MUST be changed for production (>= 32 random chars)
AUTH_SECRET="replace-me-with-a-long-random-string-at-least-32-chars"

# Bootstrap admin account (created the first time the app runs if missing)
ADMIN_EMAIL="admin@qldyouthkosta.org"
ADMIN_PASSWORD="changeme-please"
ADMIN_NAME="KOSTA Admin"
